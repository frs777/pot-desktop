{
    "build": {
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist",
        "devUrl": "http://127.0.0.1:1420"
    },
    "productName": "pot",
    "version": "3.0.7",
    "identifier": "com.pot-app.desktop",
    "plugins": {
        "updater": {
            "active": true,
            "dialog": false,
            "endpoints": [
                "https://dl.pot-app.com/https://github.com/pot-app/pot-desktop/releases/download/updater/update.json",
                "https://github.com/pot-app/pot-desktop/releases/download/updater/update.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVBRTQxQTNDQjM5QzQzM0EKUldRNlE1eXpQQnJrV21mM1Bram5LRlF6UDA3K0Jab2FYL2lZSWhXTE5McWs2NUdJS0dtYkd5VGMK"
        }
    },
    "bundle": {
        "active": true,
        "category": "Utility",
        "copyright": "GPLv3",
        "targets": "all",
        "longDescription": "A cross-platform text translation and ocr software",
        "shortDescription": "Pot App",
        "externalBin": [],
        "resources": [],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "linux": {
            "deb": {
                "depends": [
                    "libxdo-dev",
                    "libxcb1",
                    "libxrandr2",
                    "tesseract-ocr"
                ]
            },
            "rpm": {
                "depends": [
                    "libxdo",
                    "libxcb",
                    "libXrandr",
                    "tesseract-ocr"
                ]
            }
        },
        "macOS": {
            "entitlements": null,
            "exceptionDomain": "",
            "frameworks": [],
            "providerShortName": null,
            "signingIdentity": null
        }
    },
    "app": {
        "withGlobalTauri": false,
        "security": {
            "csp": "default-src * data: ; img-src * 'self' asset: https: data: ; style-src * 'unsafe-inline'; worker-src 'self' blob: ; script-src * 'unsafe-eval' 'unsafe-inline'; connect-src * 'self' http: https: ws: wss: asset:;"
        },
        "windows": [
            {
                "title": "Pot App",
                "label": "main",
                "url": "index.html",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false
            },
            {
                "title": "Daemon",
                "label": "daemon",
                "visible": false,
                "url": "daemon.html"
            }
        ]
    }
}
